generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
 }

datasource db {
  provider = "postgresql"
}

// 役職（比率）: 4:3:2:1 のような傾斜の元になる
model Role {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  ratio   Int
  members Member[]
}

// メンバー名簿
model Member {
  id           Int           @id @default(autoincrement())
  name         String
  roleId       Int
  role         Role          @relation(fields: [roleId], references: [id])
  eventMembers EventMember[]
}

// 今回の参加状況（どの飲み会で、誰が、飲むか、いくら立て替えたか）
model EventMember {
  id         Int     @id @default(autoincrement())
  eventId    Int
  memberId   Int
  isDrinking Boolean @default(true)
  amountPaid Int     @default(0)
  member     Member  @relation(fields: [memberId], references: [id])

  @@index([eventId])
}
